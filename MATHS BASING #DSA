// reverse Number
int main(){
    int n;
    cin >> n;
    int revNum =0;
    int dup=n;
    while(n>0){
        int id =n%10;
        revNum=(revNum*10)+id;
        n=n/10;
    }
    if(dup == revNum) cout << "palindrome true";
    else cout << "palindrome false";
   

}
// divisors
void printDivisors(int n){
    for(int i=1;i<=n;i++){
        if(n%i==0){
            cout << i<<" ";
        }
    }
}
int main(){
    int n;
    cin >> n;
    printDivisors(n);
    return 0;
}
// print divisor using vector list
void pf(int n){
    vector<int> ls;
    for(int i=1;i<=sqrt(n);i++){
        if(n%i==0){
            ls.push_back(i);
            if((n/i)!=i){
                ls.push_back(n/i);
            }
           sort(ls.begin(),ls.end());
           for(auto it:ls) cout<<it<<" ";
        }
    }
}
int main(){
    int n;
    cin >> n;
    pf(n);
    return 0;
}
//checking prime or not
int main(){
    int n;
    cin >> n;
    int cnt=0;
    for(int i=1;i*i<=n;i++){
        if(n%i==0){
            cnt++;
            if((n/i)!=i)cnt++;
        }
    }
    if(cnt==2)cout << "prime";
    else cout << "not prime";
}
